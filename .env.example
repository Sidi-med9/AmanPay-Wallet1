# Generated/updated by `npm start`, `npm run android`, or `npm run ios`
# (see scripts/sync-api-env.mjs). Run API with Docker in AmanPay-back first.
#
# Host port comes from API_PORT in backend .env (elmorad-api/AmanPay-back), else docker-compose
# default (${API_PORT:-3000} → 3000). Host IP: LAN for `npm start`,
# 10.0.2.2 for `npm run android`, 127.0.0.1 for `npm run ios`.
#
# Manual only: npm run sync:api-env [--preset=...]
#
# Leave EXPO_PUBLIC_API_URL empty here; the script fills .env (not this file).

EXPO_PUBLIC_API_URL=
